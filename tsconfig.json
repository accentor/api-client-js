{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "declaration": true,    
    "paths": {
      "*": ["./node_modules/*", "./src/*"]
    },
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "exclude": [
    "dist/*"
  ]
}
